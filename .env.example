# ════════════════════════════════════════════════════
# JARVIS TENDER AI — Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────
APP_NAME=JARVIS Tender AI
DEBUG=false
SECRET_KEY=your-secret-key-minimum-32-chars-here
ALLOWED_ORIGINS=https://jarvis.alltame.kz,http://localhost:3000

# ─── Database ──────────────────────────────────────
POSTGRES_PASSWORD=your_strong_database_password
DATABASE_URL=postgresql+asyncpg://jarvis:your_strong_database_password@postgres:5432/jarvis_db
DATABASE_URL_SYNC=postgresql://jarvis:your_strong_database_password@postgres:5432/jarvis_db

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OpenAI API ────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── Telegram Bot ──────────────────────────────────
# Create bot via @BotFather, get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# ─── GosZakup API ──────────────────────────────────
# Request token at: https://goszakup.gov.kz/ru/user/auth_ru
GOSZAKUP_API_TOKEN=your_goszakup_api_token

# ─── Zakup SK API ──────────────────────────────────
ZAKUPSK_API_TOKEN=your_zakupsk_api_token

# ─── Exchange Rates (fallback) ──────────────────────
USD_TO_KZT=450.0
CNY_TO_KZT=62.0
RUB_TO_KZT=4.8

# ─── Business Settings ─────────────────────────────
MIN_PROFIT_MARGIN=50.0
OPERATIONAL_COST_PERCENT=3.0
SCAN_INTERVAL_MINUTES=60
MAX_TENDERS_PER_SCAN=500

# ─── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=https://jarvis.alltame.kz
